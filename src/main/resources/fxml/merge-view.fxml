<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gitforge.controller.MergeController"
            styleClass="content-area repository-page">

    <top>
        <VBox spacing="14" styleClass="repo-toolbar-block">
            <padding>
                <Insets top="20" right="24" bottom="8" left="24"/>
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <ComboBox fx:id="repositoryComboBox" promptText="Select repository"
                          styleClass="dialog-field" prefWidth="220" prefHeight="36"/>

                <Button text="Merge Branch" styleClass="toolbar-button toolbar-button-primary"
                        onAction="#onMergeClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2s-source-merge" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Run the selected merge simulation"/>
                    </tooltip>
                </Button>

                <Button text="Merge Preview" styleClass="toolbar-button" onAction="#onPreviewClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2e-eye" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                </Button>

                <Button text="Merge History" styleClass="toolbar-button" onAction="#onHistoryClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2c-clock-outline" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                </Button>

                <Button styleClass="toolbar-button" onAction="#onRefreshClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2r-refresh" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Refresh merge workspace"/>
                    </tooltip>
                </Button>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="16" styleClass="repo-main-split">
            <padding>
                <Insets top="8" right="24" bottom="24" left="24"/>
            </padding>

            <!-- Left: merge controls -->
            <VBox spacing="12" styleClass="repo-details-card" prefWidth="280" minWidth="250">
                <padding>
                    <Insets top="14" right="14" bottom="14" left="14"/>
                </padding>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="mdi2s-source-merge" iconSize="20" styleClass="repo-details-icon"/>
                    <Label text="Merge Branches" styleClass="section-title"/>
                </HBox>

                <Label text="Source Branch" styleClass="detail-label"/>
                <ComboBox fx:id="sourceBranchComboBox" styleClass="dialog-field" maxWidth="Infinity"/>

                <Label text="Target Branch" styleClass="detail-label"/>
                <ComboBox fx:id="targetBranchComboBox" styleClass="dialog-field" maxWidth="Infinity"/>

                <Label text="Merge Strategy" styleClass="detail-label"/>
                <fx:define>
                    <ToggleGroup fx:id="strategyGroup"/>
                </fx:define>
                <RadioButton fx:id="fastForwardRadio" text="Fast Forward" toggleGroup="$strategyGroup"
                             styleClass="merge-strategy-radio" selected="true"/>
                <RadioButton fx:id="threeWayRadio" text="Three Way Merge" toggleGroup="$strategyGroup"
                             styleClass="merge-strategy-radio"/>
                <RadioButton fx:id="simulationOnlyRadio" text="Simulation Only" toggleGroup="$strategyGroup"
                             styleClass="merge-strategy-radio"/>

                <Button fx:id="mergeButton" text="Merge" styleClass="toolbar-button toolbar-button-primary"
                        maxWidth="Infinity" onAction="#onMergeClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2s-source-merge" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                </Button>
            </VBox>

            <!-- Center: preview -->
            <VBox spacing="10" styleClass="repo-table-card" HBox.hgrow="ALWAYS" minWidth="280">
                <padding>
                    <Insets top="14" right="14" bottom="14" left="14"/>
                </padding>
                <Label text="Merge Preview" styleClass="section-title"/>

                <Label fx:id="previewPlaceholderLabel" text="Select source and target branches, then click Merge Preview."
                       styleClass="placeholder-body" wrapText="true"/>

                <GridPane fx:id="previewGrid" hgap="12" vgap="10" visible="false" managed="false">
                    <columnConstraints>
                        <ColumnConstraints minWidth="140" prefWidth="150"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="140"/>
                    </columnConstraints>

                    <Label text="Source Branch" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="previewSourceLabel" styleClass="detail-value" wrapText="true"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Target Branch" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="previewTargetLabel" styleClass="detail-value" wrapText="true"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Latest Commit" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="previewLatestLabel" styleClass="detail-value" wrapText="true"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Commits to Merge" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label fx:id="previewCommitsLabel" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Expected Merge Commit" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label fx:id="previewExpectedLabel" styleClass="detail-value" wrapText="true"
                           GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label text="Potential Conflict Status" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <Label fx:id="previewConflictLabel" styleClass="detail-value detail-status"
                           GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                    <Label text="Strategy" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                    <Label fx:id="previewStrategyLabel" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                </GridPane>
            </VBox>

            <!-- Right: history -->
            <VBox spacing="10" styleClass="repo-table-card" prefWidth="360" minWidth="300">
                <padding>
                    <Insets top="14" right="14" bottom="14" left="14"/>
                </padding>
                <Label text="Merge History" styleClass="section-title"/>
                <TableView fx:id="historyTable" styleClass="repo-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" text="Merge ID" prefWidth="70"/>
                        <TableColumn fx:id="sourceColumn" text="Source" prefWidth="80"/>
                        <TableColumn fx:id="targetColumn" text="Target" prefWidth="80"/>
                        <TableColumn fx:id="strategyColumn" text="Strategy" prefWidth="100"/>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="80"/>
                        <TableColumn fx:id="timestampColumn" text="Timestamp" prefWidth="120"/>
                        <TableColumn fx:id="mergeCommitColumn" text="Merge Commit" prefWidth="90"/>
                    </columns>
                </TableView>
                <Label fx:id="historyEmptyLabel" text="No merge history yet."
                       styleClass="placeholder-body" visible="false" managed="false"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
