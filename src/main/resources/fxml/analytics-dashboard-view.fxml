<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gitforge.controller.AnalyticsController"
            fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            styleClass="page-scroll">

    <VBox spacing="18" styleClass="content-area analytics-dashboard">
        <padding>
            <Insets top="20" right="24" bottom="24" left="24"/>
        </padding>

        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="analytics-filter-bar">
            <Label text="Filters" styleClass="section-title"/>
            <ComboBox fx:id="repositoryFilter" promptText="All repositories" styleClass="dialog-field" prefWidth="180"/>
            <ComboBox fx:id="branchFilter" promptText="All branches" styleClass="dialog-field" prefWidth="150"/>
            <ComboBox fx:id="authorFilter" promptText="All authors" styleClass="dialog-field" prefWidth="150"/>
            <DatePicker fx:id="fromDatePicker" promptText="From" styleClass="dialog-field" prefWidth="130"/>
            <DatePicker fx:id="toDatePicker" promptText="To" styleClass="dialog-field" prefWidth="130"/>
            <Button text="Apply" styleClass="toolbar-button toolbar-button-primary" onAction="#onApplyFilters"/>
            <Button text="Clear" styleClass="toolbar-button" onAction="#onClearFilters"/>
            <Button text="Refresh" styleClass="toolbar-button" onAction="#onRefreshClicked">
                <graphic>
                    <FontIcon iconLiteral="mdi2r-refresh" iconSize="16" styleClass="toolbar-button-icon"/>
                </graphic>
                <tooltip>
                    <Tooltip text="Invalidate cache and reload from SQLite"/>
                </tooltip>
            </Button>
            <Label fx:id="cacheStatusLabel" text="" styleClass="stat-hint"/>
        </HBox>

        <Label text="Overview" styleClass="section-title"/>

        <GridPane fx:id="statsGrid" hgap="14" vgap="14" styleClass="stats-grid">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25" minWidth="140"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25" minWidth="140"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25" minWidth="140"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25" minWidth="140"/>
            </columnConstraints>

            <VBox fx:id="statCardRepository" styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <StackPane styleClass="stat-icon-wrap stat-icon-repo">
                        <FontIcon iconLiteral="mdi2s-source-repository" iconSize="18" styleClass="stat-icon"/>
                    </StackPane>
                    <Label text="Total Repositories" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="cardRepositoryValue" text="—" styleClass="stat-value"><VBox.margin><Insets top="12"/></VBox.margin></Label>
                <Label text="Tracked workspaces" styleClass="stat-hint"/>
            </VBox>

            <VBox fx:id="statCardCommits" styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <StackPane styleClass="stat-icon-wrap stat-icon-commits">
                        <FontIcon iconLiteral="mdi2s-source-commit" iconSize="18" styleClass="stat-icon"/>
                    </StackPane>
                    <Label text="Total Commits" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="cardCommitsValue" text="0" styleClass="stat-value"><VBox.margin><Insets top="12"/></VBox.margin></Label>
                <Label text="Across filtered scope" styleClass="stat-hint"/>
            </VBox>

            <VBox fx:id="statCardBranches" styleClass="stat-card" GridPane.columnIndex="2" GridPane.rowIndex="0">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <StackPane styleClass="stat-icon-wrap stat-icon-branch">
                        <FontIcon iconLiteral="mdi2s-source-branch" iconSize="18" styleClass="stat-icon"/>
                    </StackPane>
                    <Label text="Total Branches" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="cardBranchesValue" text="0" styleClass="stat-value"><VBox.margin><Insets top="12"/></VBox.margin></Label>
                <Label text="All branch tips" styleClass="stat-hint"/>
            </VBox>

            <VBox fx:id="statCardMerges" styleClass="stat-card" GridPane.columnIndex="3" GridPane.rowIndex="0">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <StackPane styleClass="stat-icon-wrap stat-icon-merge">
                        <FontIcon iconLiteral="mdi2s-source-merge" iconSize="18" styleClass="stat-icon"/>
                    </StackPane>
                    <Label text="Total Merges" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="cardMergesValue" text="0" styleClass="stat-value"><VBox.margin><Insets top="12"/></VBox.margin></Label>
                <Label text="Completed simulations" styleClass="stat-hint"/>
            </VBox>

            <VBox fx:id="statCardActiveBranch" styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <StackPane styleClass="stat-icon-wrap stat-icon-branch">
                        <FontIcon iconLiteral="mdi2s-source-branch" iconSize="18" styleClass="stat-icon"/>
                    </StackPane>
                    <Label text="Active Branch" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="cardActiveBranchValue" text="—" styleClass="stat-value"><VBox.margin><Insets top="12"/></VBox.margin></Label>
                <Label text="Currently checked out" styleClass="stat-hint"/>
            </VBox>

            <VBox fx:id="statCardLatestCommit" styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="1"
                  GridPane.columnSpan="2">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <StackPane styleClass="stat-icon-wrap stat-icon-commits">
                        <FontIcon iconLiteral="mdi2s-source-commit" iconSize="18" styleClass="stat-icon"/>
                    </StackPane>
                    <Label text="Latest Commit" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="cardLatestCommitValue" text="—" styleClass="stat-value" wrapText="true">
                    <VBox.margin><Insets top="12"/></VBox.margin>
                </Label>
                <Label text="Most recent activity" styleClass="stat-hint"/>
            </VBox>

            <VBox fx:id="statCardHealth" styleClass="stat-card" GridPane.columnIndex="3" GridPane.rowIndex="1">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <StackPane styleClass="stat-icon-wrap stat-icon-health">
                        <FontIcon iconLiteral="mdi2c-chart-bar" iconSize="18" styleClass="stat-icon"/>
                    </StackPane>
                    <Label text="Health Score" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="cardHealthValue" text="0" styleClass="stat-value"><VBox.margin><Insets top="12"/></VBox.margin></Label>
                <Label text="Simulated repository health" styleClass="stat-hint"/>
            </VBox>
        </GridPane>

        <Label text="Charts" styleClass="section-title"/>

        <GridPane fx:id="chartsGrid" hgap="14" vgap="14" styleClass="charts-grid">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50" minWidth="260"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50" minWidth="260"/>
            </columnConstraints>

            <VBox fx:id="chartCardRepoCommits" spacing="8" styleClass="chart-card"
                  GridPane.columnIndex="0" GridPane.rowIndex="0">
                <padding><Insets top="14" right="14" bottom="10" left="14"/></padding>
                <Label text="Commits per Repository" styleClass="chart-title"/>
                <Label text="Bar chart from SQLite commit counts" styleClass="chart-subtitle"/>
                <BarChart fx:id="commitsPerRepoChart" legendVisible="false" animated="true"
                          styleClass="dashboard-chart" VBox.vgrow="ALWAYS" minHeight="220" prefHeight="250">
                    <xAxis><CategoryAxis label="Repository" animated="false"/></xAxis>
                    <yAxis><NumberAxis label="Commits" forceZeroInRange="true" animated="false"/></yAxis>
                </BarChart>
            </VBox>

            <VBox fx:id="chartCardBranchPie" spacing="8" styleClass="chart-card"
                  GridPane.columnIndex="1" GridPane.rowIndex="0">
                <padding><Insets top="14" right="14" bottom="10" left="14"/></padding>
                <Label text="Branch Distribution" styleClass="chart-title"/>
                <Label text="Share of branches by name" styleClass="chart-subtitle"/>
                <PieChart fx:id="branchDistributionChart" animated="true" labelsVisible="true"
                          styleClass="dashboard-chart" VBox.vgrow="ALWAYS" minHeight="220" prefHeight="250"/>
            </VBox>

            <VBox fx:id="chartCardTimeline" spacing="8" styleClass="chart-card"
                  GridPane.columnIndex="0" GridPane.rowIndex="1">
                <padding><Insets top="14" right="14" bottom="10" left="14"/></padding>
                <Label text="Commit Activity Timeline" styleClass="chart-title"/>
                <Label text="Daily activity — last 14 days" styleClass="chart-subtitle"/>
                <LineChart fx:id="commitTimelineChart" createSymbols="true" legendVisible="false" animated="true"
                           styleClass="dashboard-chart" VBox.vgrow="ALWAYS" minHeight="220" prefHeight="250">
                    <xAxis><CategoryAxis label="Day" animated="false"/></xAxis>
                    <yAxis><NumberAxis label="Commits" forceZeroInRange="true" animated="false"/></yAxis>
                </LineChart>
            </VBox>

            <VBox fx:id="chartCardGrowth" spacing="8" styleClass="chart-card"
                  GridPane.columnIndex="1" GridPane.rowIndex="1">
                <padding><Insets top="14" right="14" bottom="10" left="14"/></padding>
                <Label text="Repository Growth" styleClass="chart-title"/>
                <Label text="Repositories over time" styleClass="chart-subtitle"/>
                <AreaChart fx:id="repositoryGrowthChart" legendVisible="false" animated="true"
                           createSymbols="false" styleClass="dashboard-chart" VBox.vgrow="ALWAYS"
                           minHeight="220" prefHeight="250">
                    <xAxis><CategoryAxis label="Timeline" animated="false"/></xAxis>
                    <yAxis><NumberAxis label="Repositories" forceZeroInRange="true" animated="false"/></yAxis>
                </AreaChart>
            </VBox>

            <VBox fx:id="chartCardContributors" spacing="8" styleClass="chart-card"
                  GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                <padding><Insets top="14" right="14" bottom="10" left="14"/></padding>
                <Label text="Top Contributors" styleClass="chart-title"/>
                <Label text="Authors ranked by commit count" styleClass="chart-subtitle"/>
                <BarChart fx:id="topContributorsChart" legendVisible="false" animated="true"
                          styleClass="dashboard-chart" VBox.vgrow="ALWAYS" minHeight="220" prefHeight="250">
                    <xAxis><NumberAxis label="Commits" forceZeroInRange="true" animated="false"/></xAxis>
                    <yAxis><CategoryAxis label="Author" animated="false"/></yAxis>
                </BarChart>
            </VBox>
        </GridPane>

        <HBox spacing="16" styleClass="analytics-bottom-split">
            <VBox spacing="10" styleClass="repo-table-card" HBox.hgrow="ALWAYS" minWidth="360">
                <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                <Label text="Repository Statistics" styleClass="section-title"/>
                <TableView fx:id="repositoryStatsTable" styleClass="repo-table" prefHeight="280" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="repoNameColumn" text="Repository" prefWidth="110"/>
                        <TableColumn fx:id="repoBranchColumn" text="Current Branch" prefWidth="100"/>
                        <TableColumn fx:id="repoBranchesColumn" text="Branches" prefWidth="70"/>
                        <TableColumn fx:id="repoCommitsColumn" text="Commits" prefWidth="70"/>
                        <TableColumn fx:id="repoMergesColumn" text="Merges" prefWidth="70"/>
                        <TableColumn fx:id="repoLatestColumn" text="Latest Commit" prefWidth="90"/>
                        <TableColumn fx:id="repoCreatedColumn" text="Created" prefWidth="110"/>
                        <TableColumn fx:id="repoSizeColumn" text="Size" prefWidth="70"/>
                        <TableColumn fx:id="repoStatusColumn" text="Status" prefWidth="70"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="10" styleClass="repo-details-card" prefWidth="340" minWidth="280">
                <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                <Label text="Recent Activity" styleClass="section-title"/>
                <ListView fx:id="activityList" styleClass="activity-list" VBox.vgrow="ALWAYS" prefHeight="280"/>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
