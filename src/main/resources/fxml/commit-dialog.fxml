<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/24"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gitforge.controller.CommitDialogController"
      spacing="16"
      styleClass="repo-dialog-root"
      prefWidth="480">

    <padding>
        <Insets top="20" right="22" bottom="18" left="22"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <FontIcon iconLiteral="mdi2s-source-commit" iconSize="22" styleClass="repo-details-icon"/>
        <Label text="New Commit" styleClass="dialog-title"/>
    </HBox>

    <Label fx:id="validationLabel" text="" styleClass="dialog-validation" wrapText="true"
           managed="false" visible="false"/>

    <GridPane hgap="12" vgap="12">
        <columnConstraints>
            <ColumnConstraints minWidth="120" prefWidth="130"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="240"/>
        </columnConstraints>

        <Label text="Repository *" styleClass="dialog-field-label"
               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="repositoryComboBox" styleClass="dialog-field"
                  GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity"/>

        <Label text="Branch *" styleClass="dialog-field-label"
               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="branchComboBox" styleClass="dialog-field"
                  GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity"/>

        <Label text="Commit Type" styleClass="dialog-field-label"
               GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <ComboBox fx:id="commitTypeComboBox" styleClass="dialog-field"
                  GridPane.columnIndex="1" GridPane.rowIndex="2" maxWidth="Infinity"/>

        <Label text="Author" styleClass="dialog-field-label"
               GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="authorField" promptText="GitForge User" styleClass="dialog-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Message *" styleClass="dialog-field-label"
               GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextArea fx:id="messageArea" promptText="Describe your changes"
                  styleClass="dialog-field dialog-textarea"
                  prefRowCount="4" wrapText="true"
                  GridPane.columnIndex="1" GridPane.rowIndex="4"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Cancel" styleClass="toolbar-button" onAction="#onCancel"/>
        <Button fx:id="saveButton" text="Create" styleClass="toolbar-button toolbar-button-primary"
                onAction="#onSave" defaultButton="true"/>
    </HBox>
</VBox>
