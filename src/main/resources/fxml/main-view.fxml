<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gitforge.controller.MainController"
            styleClass="root-pane">

    <left>
        <VBox styleClass="sidebar" prefWidth="248" minWidth="200" maxWidth="280">
            <padding>
                <Insets top="20" right="12" bottom="16" left="12"/>
            </padding>

            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="brand-row">
                <padding>
                    <Insets top="4" right="8" bottom="4" left="8"/>
                </padding>
                <FontIcon iconLiteral="mdi2g-git" iconSize="28" styleClass="brand-icon"/>
                <VBox spacing="2">
                    <Label text="GitForge" styleClass="brand-title"/>
                    <Label text="Git Visualizer" styleClass="brand-subtitle"/>
                </VBox>
            </HBox>

            <Separator styleClass="sidebar-separator">
                <VBox.margin>
                    <Insets top="16" bottom="12"/>
                </VBox.margin>
            </Separator>

            <Label text="NAVIGATION" styleClass="nav-section-label">
                <padding>
                    <Insets left="10" bottom="6"/>
                </padding>
            </Label>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        styleClass="sidebar-scroll" VBox.vgrow="ALWAYS">
                <VBox spacing="4" styleClass="nav-list">
                    <VBox fx:id="navDashboard" styleClass="nav-item" onMouseClicked="#onDashboardSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2v-view-dashboard-outline" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Dashboard" styleClass="nav-label"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navRepository" styleClass="nav-item" onMouseClicked="#onRepositorySelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2s-source-repository" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Repository" styleClass="nav-label"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navCommits" styleClass="nav-item" onMouseClicked="#onCommitsSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2s-source-commit" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Commits" styleClass="nav-label"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navBranches" styleClass="nav-item" onMouseClicked="#onBranchesSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2s-source-branch" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Branches" styleClass="nav-label"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navMerge" styleClass="nav-item" onMouseClicked="#onMergeSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2s-source-merge" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Merge" styleClass="nav-label"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navCommitGraph" styleClass="nav-item" onMouseClicked="#onCommitGraphSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2g-graph-outline" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Commit Graph" styleClass="nav-label"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navAnalytics" styleClass="nav-item" onMouseClicked="#onAnalyticsSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2c-chart-bar" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Analytics" styleClass="nav-label"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navSettings" styleClass="nav-item" onMouseClicked="#onSettingsSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2c-cog-outline" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Settings" styleClass="nav-label"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navAbout" styleClass="nav-item" onMouseClicked="#onAboutSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2i-information-outline" iconSize="18" styleClass="nav-icon"/>
                            <Label text="About" styleClass="nav-label"/>
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </left>

    <center>
        <BorderPane styleClass="main-shell">
            <top>
                <HBox spacing="12" alignment="CENTER_LEFT" styleClass="toolbar">
                    <padding>
                        <Insets top="12" right="20" bottom="12" left="20"/>
                    </padding>

                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="toolbarTitleLabel" text="Dashboard" styleClass="toolbar-title"/>
                        <Label fx:id="toolbarSubtitleLabel"
                               text="Simulated repository overview"
                               styleClass="toolbar-subtitle"/>
                    </VBox>

                    <Button styleClass="toolbar-button" onAction="#onRefreshClicked">
                        <graphic>
                            <FontIcon iconLiteral="mdi2r-refresh" iconSize="16" styleClass="toolbar-button-icon"/>
                        </graphic>
                        <tooltip>
                            <Tooltip text="Refresh view"/>
                        </tooltip>
                    </Button>

                    <Button styleClass="toolbar-button toolbar-button-primary" onAction="#onNewRepositoryClicked">
                        <graphic>
                            <FontIcon iconLiteral="mdi2p-plus" iconSize="16" styleClass="toolbar-button-icon"/>
                        </graphic>
                        <text>New</text>
                        <tooltip>
                            <Tooltip text="Create a simulated repository"/>
                        </tooltip>
                    </Button>
                </HBox>
            </top>

            <center>
                <StackPane styleClass="page-host">
                    <ScrollPane fx:id="dashboardPage" fitToWidth="true" hbarPolicy="NEVER"
                                vbarPolicy="AS_NEEDED" styleClass="page-scroll">
                        <VBox spacing="20" styleClass="content-area">
                            <padding>
                                <Insets top="20" right="24" bottom="24" left="24"/>
                            </padding>

                            <Label text="Overview" styleClass="section-title"/>

                            <GridPane fx:id="statsGrid" hgap="14" vgap="14" styleClass="stats-grid">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25" minWidth="140"/>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25" minWidth="140"/>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25" minWidth="140"/>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25" minWidth="140"/>
                                </columnConstraints>

                                <VBox fx:id="statCardRepository" styleClass="stat-card"
                                      GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <padding>
                                        <Insets top="16" right="16" bottom="16" left="16"/>
                                    </padding>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <StackPane styleClass="stat-icon-wrap stat-icon-repo">
                                            <FontIcon iconLiteral="mdi2s-source-repository" iconSize="18"
                                                      styleClass="stat-icon"/>
                                        </StackPane>
                                        <Label text="Repository" styleClass="stat-label"/>
                                    </HBox>
                                    <Label fx:id="cardRepositoryValue" text="—" styleClass="stat-value">
                                        <VBox.margin>
                                            <Insets top="12"/>
                                        </VBox.margin>
                                    </Label>
                                    <Label text="Active workspace" styleClass="stat-hint"/>
                                </VBox>

                                <VBox fx:id="statCardCommits" styleClass="stat-card"
                                      GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <padding>
                                        <Insets top="16" right="16" bottom="16" left="16"/>
                                    </padding>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <StackPane styleClass="stat-icon-wrap stat-icon-commits">
                                            <FontIcon iconLiteral="mdi2s-source-commit" iconSize="18"
                                                      styleClass="stat-icon"/>
                                        </StackPane>
                                        <Label text="Total Commits" styleClass="stat-label"/>
                                    </HBox>
                                    <Label fx:id="cardCommitsValue" text="0" styleClass="stat-value">
                                        <VBox.margin>
                                            <Insets top="12"/>
                                        </VBox.margin>
                                    </Label>
                                    <Label text="Across all branches" styleClass="stat-hint"/>
                                </VBox>

                                <VBox fx:id="statCardBranch" styleClass="stat-card"
                                      GridPane.columnIndex="2" GridPane.rowIndex="0">
                                    <padding>
                                        <Insets top="16" right="16" bottom="16" left="16"/>
                                    </padding>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <StackPane styleClass="stat-icon-wrap stat-icon-branch">
                                            <FontIcon iconLiteral="mdi2s-source-branch" iconSize="18"
                                                      styleClass="stat-icon"/>
                                        </StackPane>
                                        <Label text="Active Branch" styleClass="stat-label"/>
                                    </HBox>
                                    <Label fx:id="cardBranchValue" text="—" styleClass="stat-value">
                                        <VBox.margin>
                                            <Insets top="12"/>
                                        </VBox.margin>
                                    </Label>
                                    <Label text="Currently checked out" styleClass="stat-hint"/>
                                </VBox>

                                <VBox fx:id="statCardMerge" styleClass="stat-card"
                                      GridPane.columnIndex="3" GridPane.rowIndex="0">
                                    <padding>
                                        <Insets top="16" right="16" bottom="16" left="16"/>
                                    </padding>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <StackPane styleClass="stat-icon-wrap stat-icon-merge">
                                            <FontIcon iconLiteral="mdi2s-source-merge" iconSize="18"
                                                      styleClass="stat-icon"/>
                                        </StackPane>
                                        <Label text="Merge Count" styleClass="stat-label"/>
                                    </HBox>
                                    <Label fx:id="cardMergeValue" text="0" styleClass="stat-value">
                                        <VBox.margin>
                                            <Insets top="12"/>
                                        </VBox.margin>
                                    </Label>
                                    <Label text="Completed merges" styleClass="stat-hint"/>
                                </VBox>
                            </GridPane>

                            <Label text="Activity" styleClass="section-title">
                                <VBox.margin>
                                    <Insets top="4"/>
                                </VBox.margin>
                            </Label>

                            <GridPane fx:id="chartsGrid" hgap="14" vgap="14" styleClass="charts-grid"
                                      VBox.vgrow="ALWAYS">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="58" minWidth="280"/>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="42" minWidth="240"/>
                                </columnConstraints>

                                <VBox fx:id="chartCardCommits" spacing="8" styleClass="chart-card"
                                      GridPane.columnIndex="0" GridPane.rowIndex="0"
                                      GridPane.hgrow="ALWAYS" GridPane.vgrow="ALWAYS">
                                    <padding>
                                        <Insets top="14" right="14" bottom="10" left="14"/>
                                    </padding>
                                    <Label text="Commit Activity" styleClass="chart-title"/>
                                    <Label text="Placeholder trend for the last seven days"
                                           styleClass="chart-subtitle"/>
                                    <LineChart fx:id="commitActivityChart" createSymbols="true"
                                               legendVisible="false" animated="false"
                                               styleClass="dashboard-chart" VBox.vgrow="ALWAYS"
                                               minHeight="240" prefHeight="280">
                                        <xAxis>
                                            <CategoryAxis label="Day" animated="false"/>
                                        </xAxis>
                                        <yAxis>
                                            <NumberAxis label="Commits"
                                                        forceZeroInRange="true" animated="false"
                                                        autoRanging="false" lowerBound="0"
                                                        upperBound="10" tickUnit="2"/>
                                        </yAxis>
                                    </LineChart>
                                </VBox>

                                <VBox fx:id="chartCardBranches" spacing="8" styleClass="chart-card"
                                      GridPane.columnIndex="1" GridPane.rowIndex="0"
                                      GridPane.hgrow="ALWAYS" GridPane.vgrow="ALWAYS">
                                    <padding>
                                        <Insets top="14" right="14" bottom="10" left="14"/>
                                    </padding>
                                    <Label text="Branch Activity" styleClass="chart-title"/>
                                    <Label text="Placeholder commits by branch"
                                           styleClass="chart-subtitle"/>
                                    <BarChart fx:id="branchActivityChart" legendVisible="false"
                                              animated="false" categoryGap="18"
                                              styleClass="dashboard-chart" VBox.vgrow="ALWAYS"
                                              minHeight="240" prefHeight="280">
                                        <xAxis>
                                            <CategoryAxis label="Branch" animated="false"/>
                                        </xAxis>
                                        <yAxis>
                                            <NumberAxis label="Commits"
                                                        forceZeroInRange="true" animated="false"
                                                        autoRanging="false" lowerBound="0"
                                                        upperBound="12" tickUnit="2"/>
                                        </yAxis>
                                    </BarChart>
                                </VBox>
                            </GridPane>
                        </VBox>
                    </ScrollPane>

                    <fx:include fx:id="repositoryPage" source="repository-view.fxml"
                                visible="false" managed="false"/>

                    <VBox fx:id="modulePlaceholderPage" alignment="CENTER" spacing="14"
                          styleClass="content-area module-placeholder" managed="false" visible="false">
                        <padding>
                            <Insets top="40" right="40" bottom="40" left="40"/>
                        </padding>
                        <FontIcon fx:id="placeholderIcon" iconLiteral="mdi2g-git" iconSize="52"
                                  styleClass="placeholder-icon"/>
                        <Label fx:id="placeholderTitleLabel" text="Module" styleClass="placeholder-title"/>
                        <Label fx:id="placeholderBodyLabel"
                               text="This module will be implemented in a later release."
                               styleClass="placeholder-body"
                               wrapText="true"
                               maxWidth="480"
                               alignment="CENTER"/>
                    </VBox>
                </StackPane>
            </center>

            <bottom>
                <HBox spacing="16" alignment="CENTER_LEFT" styleClass="status-bar">
                    <padding>
                        <Insets top="8" right="16" bottom="8" left="16"/>
                    </padding>

                    <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                        <FontIcon iconLiteral="mdi2c-circle-medium" iconSize="14" styleClass="status-ready-icon"/>
                        <Label fx:id="statusMessageLabel" text="Ready" styleClass="status-message"/>
                    </HBox>

                    <Separator orientation="VERTICAL" styleClass="status-separator" prefHeight="14"/>

                    <Label fx:id="statusPageLabel" text="Dashboard" styleClass="status-page"/>

                    <Separator orientation="VERTICAL" styleClass="status-separator" prefHeight="14"/>

                    <Label text="GitForge 1.0.0" styleClass="status-version"/>
                </HBox>
            </bottom>
        </BorderPane>
    </center>
</BorderPane>
