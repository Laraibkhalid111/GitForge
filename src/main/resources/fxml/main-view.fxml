<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gitforge.controller.MainController"
            styleClass="root-pane">

    <!-- Left Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="260" minWidth="220" maxWidth="300">
            <padding>
                <Insets top="24" right="16" bottom="24" left="16"/>
            </padding>

            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="brand-row">
                <FontIcon iconLiteral="mdi2g-git" iconSize="28" styleClass="brand-icon"/>
                <VBox spacing="2">
                    <Label text="GitForge" styleClass="brand-title"/>
                    <Label text="Git Visualizer" styleClass="brand-subtitle"/>
                </VBox>
            </HBox>

            <Separator styleClass="sidebar-separator">
                <VBox.margin>
                    <Insets top="20" bottom="16"/>
                </VBox.margin>
            </Separator>

            <Label text="NAVIGATION" styleClass="nav-section-label"/>

            <VBox spacing="6" styleClass="nav-list">
                <VBox.margin>
                    <Insets top="8"/>
                </VBox.margin>

                <VBox fx:id="navDashboard" spacing="0" styleClass="nav-item" onMouseClicked="#onDashboardSelected">
                    <padding>
                        <Insets top="12" right="14" bottom="12" left="14"/>
                    </padding>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="mdi2v-view-dashboard-outline" iconSize="18" styleClass="nav-icon"/>
                        <Label text="Dashboard" styleClass="nav-label"/>
                    </HBox>
                </VBox>

                <VBox fx:id="navRepositories" spacing="0" styleClass="nav-item" onMouseClicked="#onRepositoriesSelected">
                    <padding>
                        <Insets top="12" right="14" bottom="12" left="14"/>
                    </padding>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="mdi2s-source-repository" iconSize="18" styleClass="nav-icon"/>
                        <Label text="Repositories" styleClass="nav-label"/>
                    </HBox>
                </VBox>

                <VBox fx:id="navCommits" spacing="0" styleClass="nav-item" onMouseClicked="#onCommitsSelected">
                    <padding>
                        <Insets top="12" right="14" bottom="12" left="14"/>
                    </padding>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="mdi2s-source-commit" iconSize="18" styleClass="nav-icon"/>
                        <Label text="Commits" styleClass="nav-label"/>
                    </HBox>
                </VBox>

                <VBox fx:id="navBranches" spacing="0" styleClass="nav-item" onMouseClicked="#onBranchesSelected">
                    <padding>
                        <Insets top="12" right="14" bottom="12" left="14"/>
                    </padding>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="mdi2s-source-branch" iconSize="18" styleClass="nav-icon"/>
                        <Label text="Branches" styleClass="nav-label"/>
                    </HBox>
                </VBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox fx:id="navSettings" spacing="0" styleClass="nav-item" onMouseClicked="#onSettingsSelected">
                <padding>
                    <Insets top="12" right="14" bottom="12" left="14"/>
                </padding>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="mdi2c-cog-outline" iconSize="18" styleClass="nav-icon"/>
                    <Label text="Settings" styleClass="nav-label"/>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox styleClass="content-area" spacing="24">
            <padding>
                <Insets top="32" right="36" bottom="32" left="36"/>
            </padding>

            <VBox spacing="8" styleClass="page-header">
                <Label fx:id="contentTitleLabel" text="Dashboard" styleClass="page-title"/>
                <Label fx:id="contentSubtitleLabel"
                       text="Overview of your simulated repositories. Content will be wired in a later module."
                       styleClass="page-subtitle"
                       wrapText="true"/>
            </VBox>

            <!-- Dashboard placeholder card -->
            <StackPane styleClass="placeholder-card" VBox.vgrow="ALWAYS" minHeight="280">
                <VBox spacing="12" alignment="CENTER" maxWidth="480">
                    <FontIcon iconLiteral="mdi2g-git" iconSize="48" styleClass="placeholder-icon"/>
                    <Label text="Dashboard Placeholder" styleClass="placeholder-title"/>
                    <Label text="Repository overview, recent commits, and branch stats will appear here once those modules are built."
                           styleClass="placeholder-body"
                           wrapText="true"
                           alignment="CENTER"
                           maxWidth="420"/>
                </VBox>
            </StackPane>
        </VBox>
    </center>
</BorderPane>
