<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXProgressSpinner?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gitforge.controller.MainController"
            styleClass="root-pane">

    <left>
        <VBox styleClass="sidebar" prefWidth="248" minWidth="200" maxWidth="280">
            <padding>
                <Insets top="20" right="12" bottom="16" left="12"/>
            </padding>

            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="brand-row">
                <padding>
                    <Insets top="4" right="8" bottom="4" left="8"/>
                </padding>
                <StackPane styleClass="brand-icon-wrap">
                    <FontIcon iconLiteral="mdi2g-git" iconSize="26" styleClass="brand-icon"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="GitForge" styleClass="brand-title"/>
                    <Label text="Git Visualizer" styleClass="brand-subtitle"/>
                </VBox>
            </HBox>

            <Separator styleClass="sidebar-separator">
                <VBox.margin>
                    <Insets top="16" bottom="12"/>
                </VBox.margin>
            </Separator>

            <Label text="NAVIGATION" styleClass="nav-section-label">
                <padding>
                    <Insets left="10" bottom="6"/>
                </padding>
            </Label>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        styleClass="sidebar-scroll" VBox.vgrow="ALWAYS">
                <VBox spacing="4" styleClass="nav-list">
                    <VBox fx:id="navDashboard" styleClass="nav-item" onMouseClicked="#onDashboardSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2v-view-dashboard-outline" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Dashboard" styleClass="nav-label"/>
                            <Label text="Ctrl+1" styleClass="nav-shortcut"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navRepository" styleClass="nav-item" onMouseClicked="#onRepositorySelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2s-source-repository" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Repository" styleClass="nav-label"/>
                            <Label text="Ctrl+2" styleClass="nav-shortcut"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navCommits" styleClass="nav-item" onMouseClicked="#onCommitsSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2s-source-commit" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Commits" styleClass="nav-label"/>
                            <Label text="Ctrl+3" styleClass="nav-shortcut"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navBranches" styleClass="nav-item" onMouseClicked="#onBranchesSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2s-source-branch" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Branches" styleClass="nav-label"/>
                            <Label text="Ctrl+4" styleClass="nav-shortcut"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navMerge" styleClass="nav-item" onMouseClicked="#onMergeSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2s-source-merge" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Merge" styleClass="nav-label"/>
                            <Label text="Ctrl+5" styleClass="nav-shortcut"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navCommitGraph" styleClass="nav-item" onMouseClicked="#onCommitGraphSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2g-graph-outline" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Commit Graph" styleClass="nav-label"/>
                            <Label text="Ctrl+6" styleClass="nav-shortcut"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navAnalytics" styleClass="nav-item" onMouseClicked="#onAnalyticsSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2c-chart-bar" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Analytics" styleClass="nav-label"/>
                            <Label text="Ctrl+7" styleClass="nav-shortcut"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navSettings" styleClass="nav-item" onMouseClicked="#onSettingsSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2c-cog-outline" iconSize="18" styleClass="nav-icon"/>
                            <Label text="Settings" styleClass="nav-label"/>
                            <Label text="Ctrl+," styleClass="nav-shortcut"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="navAbout" styleClass="nav-item" onMouseClicked="#onAboutSelected">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="mdi2i-information-outline" iconSize="18" styleClass="nav-icon"/>
                            <Label text="About" styleClass="nav-label"/>
                            <Label text="F1" styleClass="nav-shortcut"/>
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>

            <Label text="GitForge Desktop" styleClass="sidebar-footer"/>
        </VBox>
    </left>

    <center>
        <StackPane>
            <BorderPane styleClass="main-shell">
                <top>
                    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="toolbar">
                        <padding>
                            <Insets top="12" right="20" bottom="12" left="20"/>
                        </padding>

                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label fx:id="toolbarTitleLabel" text="Dashboard" styleClass="toolbar-title"/>
                            <Label fx:id="toolbarSubtitleLabel"
                                   text="Simulated repository overview"
                                   styleClass="toolbar-subtitle"/>
                        </VBox>

                        <Button styleClass="toolbar-button" onAction="#onRefreshClicked">
                            <graphic>
                                <FontIcon iconLiteral="mdi2r-refresh" iconSize="16" styleClass="toolbar-button-icon"/>
                            </graphic>
                            <tooltip>
                                <Tooltip text="Refresh view (Ctrl+R / F5)"/>
                            </tooltip>
                        </Button>

                        <Button styleClass="toolbar-button toolbar-button-primary" onAction="#onNewRepositoryClicked">
                            <graphic>
                                <FontIcon iconLiteral="mdi2p-plus" iconSize="16" styleClass="toolbar-button-icon"/>
                            </graphic>
                            <text>New</text>
                            <tooltip>
                                <Tooltip text="Create a simulated repository (Ctrl+N)"/>
                            </tooltip>
                        </Button>
                    </HBox>
                </top>

                <center>
                    <StackPane styleClass="page-host">
                        <fx:include fx:id="dashboardPage" source="analytics-dashboard-view.fxml"/>

                        <fx:include fx:id="repositoryPage" source="repository-view.fxml"
                                    visible="false" managed="false"/>

                        <fx:include fx:id="commitPage" source="commit-view.fxml"
                                    visible="false" managed="false"/>

                        <fx:include fx:id="branchPage" source="branch-view.fxml"
                                    visible="false" managed="false"/>

                        <fx:include fx:id="mergePage" source="merge-view.fxml"
                                    visible="false" managed="false"/>

                        <fx:include fx:id="commitGraphPage" source="commit-graph-view.fxml"
                                    visible="false" managed="false"/>

                        <VBox fx:id="modulePlaceholderPage" alignment="CENTER" spacing="14"
                              styleClass="content-area module-placeholder" managed="false" visible="false">
                            <padding>
                                <Insets top="40" right="40" bottom="40" left="40"/>
                            </padding>
                            <FontIcon fx:id="placeholderIcon" iconLiteral="mdi2g-git" iconSize="52"
                                      styleClass="placeholder-icon"/>
                            <Label fx:id="placeholderTitleLabel" text="Module" styleClass="placeholder-title"/>
                            <Label fx:id="placeholderBodyLabel"
                                   text="This module will be implemented in a later release."
                                   styleClass="placeholder-body"
                                   wrapText="true"
                                   maxWidth="520"
                                   alignment="CENTER"/>
                        </VBox>
                    </StackPane>
                </center>

                <bottom>
                    <HBox spacing="16" alignment="CENTER_LEFT" styleClass="status-bar">
                        <padding>
                            <Insets top="8" right="16" bottom="8" left="16"/>
                        </padding>

                        <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                            <FontIcon iconLiteral="mdi2c-circle-medium" iconSize="14" styleClass="status-ready-icon"/>
                            <Label fx:id="statusMessageLabel" text="Ready" styleClass="status-message"/>
                        </HBox>

                        <Separator orientation="VERTICAL" styleClass="status-separator" prefHeight="14"/>

                        <Label fx:id="statusPageLabel" text="Dashboard" styleClass="status-page"/>

                        <Separator orientation="VERTICAL" styleClass="status-separator" prefHeight="14"/>

                        <Label fx:id="statusVersionLabel" text="GitForge" styleClass="status-version"/>
                    </HBox>
                </bottom>
            </BorderPane>

            <StackPane fx:id="notificationHost" mouseTransparent="true" pickOnBounds="false"/>

            <StackPane fx:id="loadingOverlay" styleClass="loading-overlay" visible="false" managed="false">
                <VBox spacing="12" alignment="CENTER" styleClass="loading-panel">
                    <MFXProgressSpinner fx:id="loadingSpinner" radius="18"/>
                    <Label text="Refreshing…" styleClass="loading-label"/>
                </VBox>
            </StackPane>
        </StackPane>
    </center>
</BorderPane>
