<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gitforge.controller.CommitGraphController"
            styleClass="content-area repository-page">

    <top>
        <VBox spacing="14" styleClass="repo-toolbar-block">
            <padding>
                <Insets top="20" right="24" bottom="8" left="24"/>
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <ComboBox fx:id="repositoryComboBox" promptText="Select repository"
                          styleClass="dialog-field" prefWidth="220" prefHeight="36"/>

                <Button text="Refresh Graph" styleClass="toolbar-button" onAction="#onRefreshClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2r-refresh" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                </Button>

                <Button text="Auto Layout" styleClass="toolbar-button" onAction="#onAutoLayoutClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2v-view-dashboard-outline" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                </Button>

                <Button text="Zoom In" styleClass="toolbar-button" onAction="#onZoomInClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2p-plus" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                </Button>

                <Button text="Zoom Out" styleClass="toolbar-button" onAction="#onZoomOutClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2m-minus" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                </Button>

                <Button text="Center Graph" styleClass="toolbar-button" onAction="#onCenterClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2g-graph-outline" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                </Button>

                <Button fx:id="colorsButton" text="Toggle Colors" styleClass="toolbar-button"
                        onAction="#onToggleColorsClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2c-circle-medium" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                </Button>

                <Button text="Export PNG" styleClass="toolbar-button" onAction="#onExportClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2f-file-export-outline" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Export the graph canvas as PNG"/>
                    </tooltip>
                </Button>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="16" styleClass="repo-main-split">
            <padding>
                <Insets top="8" right="24" bottom="24" left="24"/>
            </padding>

            <VBox spacing="10" styleClass="repo-table-card" HBox.hgrow="ALWAYS" minWidth="480">
                <padding>
                    <Insets top="14" right="14" bottom="14" left="14"/>
                </padding>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Commit Graph" styleClass="section-title"/>
                    <HBox fx:id="legendBox" spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"/>
                </HBox>

                <Label fx:id="emptyLabel" text="Select a repository with commits to visualize the DAG."
                       styleClass="placeholder-body" wrapText="true" visible="true" managed="true"/>

                <ScrollPane fx:id="graphScroll" styleClass="graph-scroll" fitToWidth="false" fitToHeight="false"
                            VBox.vgrow="ALWAYS" pannable="true">
                    <content>
                        <Pane fx:id="graphCanvas" styleClass="graph-canvas" minWidth="800" minHeight="500"/>
                    </content>
                </ScrollPane>
            </VBox>

            <VBox spacing="10" styleClass="repo-details-card" prefWidth="320" minWidth="280">
                <padding>
                    <Insets top="14" right="14" bottom="14" left="14"/>
                </padding>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="mdi2s-source-commit" iconSize="20" styleClass="repo-details-icon"/>
                    <Label text="Node Details" styleClass="section-title"/>
                </HBox>

                <Label fx:id="detailsPlaceholderLabel" text="Click a commit node to inspect details."
                       styleClass="placeholder-body" wrapText="true"/>

                <GridPane fx:id="detailsGrid" hgap="10" vgap="8" visible="false" managed="false">
                    <columnConstraints>
                        <ColumnConstraints minWidth="110" prefWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="140"/>
                    </columnConstraints>

                    <Label text="Commit Hash" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="detailHashLabel" wrapText="true" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Message" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="detailMessageLabel" wrapText="true" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Author" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="detailAuthorLabel" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Timestamp" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label fx:id="detailTimestampLabel" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Branch" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label fx:id="detailBranchLabel" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label text="Parent Commit" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <Label fx:id="detailParentLabel" wrapText="true" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                    <Label text="Merge Commit" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                    <Label fx:id="detailMergeLabel" wrapText="true" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                    <Label text="Files Changed" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                    <Label fx:id="detailFilesLabel" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="7"/>
                </GridPane>
            </VBox>
        </HBox>
    </center>
</BorderPane>
