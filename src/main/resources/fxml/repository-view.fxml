<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gitforge.controller.RepositoryController"
            styleClass="content-area repository-page">

    <top>
        <VBox spacing="14" styleClass="repo-toolbar-block">
            <padding>
                <Insets top="20" right="24" bottom="8" left="24"/>
            </padding>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search repositories..."
                           styleClass="repo-search-field" HBox.hgrow="ALWAYS" prefHeight="36"/>

                <Button fx:id="newButton" text="New Repository"
                        styleClass="toolbar-button toolbar-button-primary" onAction="#onNewClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2p-plus" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Create a simulated repository"/>
                    </tooltip>
                </Button>

                <Button fx:id="editButton" text="Edit"
                        styleClass="toolbar-button" onAction="#onEditClicked" disable="true">
                    <graphic>
                        <FontIcon iconLiteral="mdi2p-pencil-outline" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                </Button>

                <Button fx:id="deleteButton" text="Delete"
                        styleClass="toolbar-button toolbar-button-danger" onAction="#onDeleteClicked" disable="true">
                    <graphic>
                        <FontIcon iconLiteral="mdi2d-delete-outline" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                </Button>

                <Button fx:id="refreshButton" styleClass="toolbar-button" onAction="#onRefreshClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2r-refresh" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Refresh repository list"/>
                    </tooltip>
                </Button>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="16" styleClass="repo-main-split">
            <padding>
                <Insets top="8" right="24" bottom="24" left="24"/>
            </padding>

            <VBox spacing="10" styleClass="repo-table-card" HBox.hgrow="ALWAYS" minWidth="420">
                <padding>
                    <Insets top="14" right="14" bottom="14" left="14"/>
                </padding>
                <Label text="Repositories" styleClass="section-title"/>
                <TableView fx:id="repositoryTable" styleClass="repo-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="nameColumn" text="Repository Name" prefWidth="160"/>
                        <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="180"/>
                        <TableColumn fx:id="branchColumn" text="Current Branch" prefWidth="120"/>
                        <TableColumn fx:id="commitsColumn" text="Total Commits" prefWidth="110"/>
                        <TableColumn fx:id="createdColumn" text="Created Date" prefWidth="130"/>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="90"/>
                    </columns>
                </TableView>
                <Label fx:id="emptyLabel" text="No repositories yet. Create one to get started."
                       styleClass="repo-empty-label" managed="false" visible="false"/>
            </VBox>

            <VBox spacing="12" styleClass="repo-details-card" prefWidth="300" minWidth="260" maxWidth="360">
                <padding>
                    <Insets top="16" right="16" bottom="16" left="16"/>
                </padding>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="mdi2s-source-repository" iconSize="22" styleClass="repo-details-icon"/>
                    <Label text="Details" styleClass="section-title"/>
                </HBox>

                <Label fx:id="detailsPlaceholderLabel"
                       text="Select a repository to view details."
                       styleClass="repo-details-placeholder"
                       wrapText="true"/>

                <GridPane fx:id="detailsGrid" hgap="10" vgap="12" styleClass="repo-details-grid"
                          managed="false" visible="false">
                    <columnConstraints>
                        <ColumnConstraints minWidth="110" prefWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="120"/>
                    </columnConstraints>

                    <Label text="Repository Name" styleClass="detail-label"
                           GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="detailNameLabel" styleClass="detail-value" wrapText="true"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Description" styleClass="detail-label"
                           GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="detailDescriptionLabel" styleClass="detail-value" wrapText="true"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Repository Path" styleClass="detail-label"
                           GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="detailPathLabel" styleClass="detail-value" wrapText="true"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Creation Date" styleClass="detail-label"
                           GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label fx:id="detailCreatedLabel" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Current Branch" styleClass="detail-label"
                           GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label fx:id="detailBranchLabel" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label text="Total Branches" styleClass="detail-label"
                           GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <Label fx:id="detailBranchCountLabel" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                    <Label text="Total Commits" styleClass="detail-label"
                           GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                    <Label fx:id="detailCommitCountLabel" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                    <Label text="Repository Status" styleClass="detail-label"
                           GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                    <Label fx:id="detailStatusLabel" styleClass="detail-value detail-status"
                           GridPane.columnIndex="1" GridPane.rowIndex="7"/>
                </GridPane>

                <Region VBox.vgrow="ALWAYS"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
