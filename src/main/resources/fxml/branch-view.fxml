<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/24"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gitforge.controller.BranchController"
            styleClass="content-area repository-page">

    <top>
        <VBox spacing="14" styleClass="repo-toolbar-block">
            <padding>
                <Insets top="20" right="24" bottom="8" left="24"/>
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <ComboBox fx:id="repositoryComboBox" promptText="All repositories"
                          styleClass="dialog-field" prefWidth="180" prefHeight="36"/>

                <TextField fx:id="searchField" promptText="Search branches..."
                           styleClass="repo-search-field" HBox.hgrow="ALWAYS" prefHeight="36"/>

                <Button text="Create Branch" styleClass="toolbar-button toolbar-button-primary"
                        onAction="#onCreateClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2p-plus" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Create a simulated branch"/>
                    </tooltip>
                </Button>

                <Button fx:id="renameButton" text="Rename" styleClass="toolbar-button"
                        onAction="#onRenameClicked" disable="true">
                    <graphic>
                        <FontIcon iconLiteral="mdi2p-pencil-outline" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                </Button>

                <Button fx:id="deleteButton" text="Delete" styleClass="toolbar-button toolbar-button-danger"
                        onAction="#onDeleteClicked" disable="true">
                    <graphic>
                        <FontIcon iconLiteral="mdi2d-delete-outline" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                </Button>

                <Button fx:id="switchButton" text="Switch" styleClass="toolbar-button"
                        onAction="#onSwitchClicked" disable="true">
                    <graphic>
                        <FontIcon iconLiteral="mdi2s-source-branch" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Switch the active branch"/>
                    </tooltip>
                </Button>

                <Button fx:id="mergeButton" text="Merge" styleClass="toolbar-button"
                        onAction="#onMergeClicked" disable="true">
                    <graphic>
                        <FontIcon iconLiteral="mdi2s-source-merge" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Open Merge simulation guidance"/>
                    </tooltip>
                </Button>

                <Button styleClass="toolbar-button" onAction="#onRefreshClicked">
                    <graphic>
                        <FontIcon iconLiteral="mdi2r-refresh" iconSize="16" styleClass="toolbar-button-icon"/>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Refresh branch list"/>
                    </tooltip>
                </Button>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="16" styleClass="repo-main-split">
            <padding>
                <Insets top="8" right="24" bottom="24" left="24"/>
            </padding>

            <VBox spacing="10" styleClass="repo-table-card" HBox.hgrow="ALWAYS" minWidth="420">
                <padding>
                    <Insets top="14" right="14" bottom="14" left="14"/>
                </padding>
                <Label text="Branches" styleClass="section-title"/>
                <TableView fx:id="branchTable" styleClass="repo-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="nameColumn" text="Branch Name" prefWidth="120"/>
                        <TableColumn fx:id="repositoryColumn" text="Repository" prefWidth="110"/>
                        <TableColumn fx:id="parentColumn" text="Parent Branch" prefWidth="110"/>
                        <TableColumn fx:id="createdColumn" text="Created Date" prefWidth="130"/>
                        <TableColumn fx:id="latestCommitColumn" text="Latest Commit" prefWidth="100"/>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="80"/>
                        <TableColumn fx:id="commitsColumn" text="Commits" prefWidth="70"/>
                    </columns>
                </TableView>
                <Label fx:id="emptyLabel" text="No branches yet. Create a repository first."
                       styleClass="placeholder-body" visible="false" managed="false"/>

                <Label text="Branch Hierarchy" styleClass="section-title"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Tree from the selected repository" styleClass="chart-subtitle" HBox.hgrow="ALWAYS"/>
                    <Button text="View Branch Tree" styleClass="toolbar-button" onAction="#onViewTreeClicked">
                        <graphic>
                            <FontIcon iconLiteral="mdi2f-file-tree" iconSize="16" styleClass="toolbar-button-icon"/>
                        </graphic>
                        <tooltip>
                            <Tooltip text="Rebuild and show the branch tree"/>
                        </tooltip>
                    </Button>
                </HBox>
                <TextArea fx:id="hierarchyArea" editable="false" wrapText="false" prefRowCount="8"
                          styleClass="hierarchy-area"
                          promptText="Select a repository to view the branch tree."
                          VBox.vgrow="ALWAYS"/>
            </VBox>

            <VBox spacing="10" styleClass="repo-details-card" prefWidth="320" minWidth="280">
                <padding>
                    <Insets top="14" right="14" bottom="14" left="14"/>
                </padding>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="mdi2s-source-branch" iconSize="20" styleClass="repo-details-icon"/>
                    <Label text="Branch Details" styleClass="section-title"/>
                </HBox>

                <Label fx:id="detailsPlaceholderLabel" text="Select a branch to view details."
                       styleClass="placeholder-body" wrapText="true"/>

                <GridPane fx:id="detailsGrid" hgap="10" vgap="8" visible="false" managed="false">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="110"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="140"/>
                    </columnConstraints>

                    <Label text="Branch Name" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="detailNameLabel" wrapText="true" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Repository" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="detailRepositoryLabel" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Parent Branch" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="detailParentLabel" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Created Date" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label fx:id="detailCreatedLabel" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Latest Commit" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label fx:id="detailLatestCommitLabel" wrapText="true" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label text="Total Commits" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <Label fx:id="detailCommitCountLabel" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                    <Label text="Current Status" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                    <Label fx:id="detailStatusLabel" styleClass="detail-value detail-status"
                           GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                    <Label text="Description" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                    <Label fx:id="detailDescriptionLabel" wrapText="true" styleClass="detail-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="7"/>
                </GridPane>
            </VBox>
        </HBox>
    </center>
</BorderPane>
